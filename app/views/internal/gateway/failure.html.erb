<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <style>
      body {
        margin: 0;
        background: #f6f8fb;
        color: #18212f;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      main {
        box-sizing: border-box;
        width: min(680px, calc(100% - 32px));
        margin: 0 auto;
        padding: 72px 0;
      }

      .eyebrow {
        margin: 0 0 12px;
        color: #526170;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
      }

      h1 {
        margin: 0 0 16px;
        font-size: 2.5rem;
        line-height: 1.05;
      }

      p {
        margin: 0 0 12px;
        color: #405066;
        font-size: 1.05rem;
        line-height: 1.6;
      }

      a {
        display: inline-flex;
        align-items: center;
        min-height: 40px;
        padding: 0 14px;
        border-radius: 8px;
        background: #265a8f;
        color: #ffffff;
        font-weight: 700;
        text-decoration: none;
      }

      .actions {
        margin-top: 24px;
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">HobbyRepository</p>
      <h1><%= heading %></h1>
      <p><%= message %></p>
      <p><%= detail %></p>
      <% if dashboard_path.present? %>
        <p class="actions"><%= link_to "Open dashboard", dashboard_path %></p>
      <% end %>
    </main>
  </body>
</html>
