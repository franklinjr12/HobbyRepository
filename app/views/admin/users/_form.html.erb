<% if user.errors.any? %>
  <div class="error-panel">
    <h2><%= pluralize(user.errors.count, "error") %> prevented this user from being saved</h2>
    <ul>
      <% user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [ :admin, user ], class: "stacked-form" do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name, autocomplete: "name" %>
  </div>

  <div>
    <%= form.label :email %>
    <%= form.email_field :email, required: true, autocomplete: "email" %>
  </div>

  <div>
    <%= form.label :password %>
    <%= form.password_field :password, required: true, autocomplete: "new-password" %>
  </div>

  <div>
    <%= form.label :password_confirmation %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
  </div>

  <label class="checkbox-row">
    <%= form.check_box :admin %>
    Admin user
  </label>

  <%= form.submit "Create user" %>
<% end %>
