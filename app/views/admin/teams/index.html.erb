<% content_for :title, "Admin Teams" %>

<main class="page-shell">
  <header class="page-header">
    <div>
      <p class="eyebrow">Admin</p>
      <h1>Teams</h1>
    </div>
    <div class="inline-actions">
      <%= link_to "All apps", admin_apps_path, class: "button secondary" %>
      <%= link_to "Users", admin_users_path, class: "button secondary" %>
      <%= link_to "New team", new_admin_team_path, class: "button" %>
    </div>
  </header>

  <% if @teams.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Slug</th>
          <th>Members</th>
          <th>Apps</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @teams.each do |team| %>
          <tr>
            <td><%= team.name %></td>
            <td><%= team.slug %></td>
            <td><%= pluralize(team.team_memberships.size, "member") %></td>
            <td><%= pluralize(team.apps.size, "app") %></td>
            <td><%= time_ago_in_words(team.created_at) %> ago</td>
            <td>
              <div class="inline-actions">
                <%= link_to "Edit", edit_admin_team_path(team), class: "button compact secondary" %>
                <%= button_to "Delete", admin_team_path(team),
                              method: :delete,
                              class: "button compact secondary",
                              form: { data: { turbo_confirm: "Delete #{team.name}?" } } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">No teams have been created yet.</p>
  <% end %>
</main>
