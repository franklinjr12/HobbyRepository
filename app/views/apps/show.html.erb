<% content_for :title, @app.name %>

<main class="page-shell">
  <header class="page-header">
    <div>
      <p class="eyebrow"><%= @app.slug %></p>
      <h1><%= @app.name %></h1>
    </div>
    <div class="inline-actions">
      <%= link_to "Settings", edit_app_path(@app), class: "button secondary" %>
      <%= link_to "Logs", app_app_logs_path(@app), class: "button secondary" %>
      <%= button_to "Wake", wake_app_path(@app), method: :post, class: "button" %>
      <%= button_to "Sleep", sleep_app_path(@app), method: :post, class: "button secondary", form: { data: { turbo_confirm: "Put this app to sleep now?" } } %>
      <%= button_to "Inspect", inspect_runtime_app_path(@app), method: :post, class: "button secondary" %>
      <%= link_to "All apps", apps_path, class: "button secondary" %>
    </div>
  </header>

  <section class="dashboard-grid">
    <article>
      <span class="status-dot"></span>
      <h2>Status</h2>
      <p><span class="status-pill status-<%= @app.status %>"><%= @app.status.humanize %></span></p>
    </article>
    <article>
      <span class="status-dot"></span>
      <h2>Route</h2>
      <% if @app.default_route&.hostname.present? %>
        <p><%= link_to @app.default_route.hostname, "http://#{@app.default_route.hostname}", target: "_blank", rel: "noopener" %></p>
      <% else %>
        <p>Not routed</p>
      <% end %>
    </article>
    <article>
      <span class="status-dot"></span>
      <h2>Runtime</h2>
      <p><%= @runtime_instance&.status || "No runtime instance" %></p>
    </article>
    <article>
      <span class="status-dot"></span>
      <h2>Traffic</h2>
      <p><%= pluralize(@app.request_count, "request") %>, <%= pluralize(@app.cold_start_count, "cold start") %></p>
    </article>
    <article>
      <span class="status-dot"></span>
      <h2>Wake Time</h2>
      <p><%= @app.average_wake_duration_ms ? "#{@app.average_wake_duration_ms} ms average" : "No wake data yet" %></p>
    </article>
  </section>

  <section class="detail-grid">
    <article>
      <h2>Configuration</h2>
      <dl>
        <dt>Image</dt>
        <dd><%= @app.image_reference.presence || "Not configured" %></dd>
        <dt>Internal port</dt>
        <dd><%= @app.internal_port.presence || "Not configured" %></dd>
        <dt>Health check</dt>
        <dd><%= @app.health_check_kind.humanize %><%= " #{@app.health_check_path}" if @app.health_check_path.present? %></dd>
        <dt>Idle timeout</dt>
        <dd><%= pluralize(@app.idle_timeout_seconds, "second") %></dd>
        <dt>Last request</dt>
        <dd><%= @app.last_request_at || "No traffic yet" %></dd>
        <dt>Active requests</dt>
        <dd><%= @app.active_request_count %></dd>
        <dt>Active connections</dt>
        <dd><%= @app.active_connection_count %></dd>
        <dt>Startup timeout</dt>
        <dd><%= pluralize(@app.startup_timeout_seconds, "second") %></dd>
        <dt>Memory limit</dt>
        <dd><%= @app.memory_limit_bytes.presence || "No limit configured" %></dd>
        <dt>CPU limit</dt>
        <dd><%= @app.cpu_limit.presence || "No limit configured" %></dd>
      </dl>
    </article>

    <article>
      <h2>Current Deployment</h2>
      <% if @app.current_deployment %>
        <dl>
          <dt>Status</dt>
          <dd><%= @app.current_deployment.status.humanize %></dd>
          <dt>Image</dt>
          <dd><%= @app.current_deployment.image_reference %></dd>
          <dt>Port</dt>
          <dd><%= @app.current_deployment.port %></dd>
          <dt>Health check</dt>
          <dd><%= @app.current_deployment.health_check_kind.humanize %><%= " #{@app.current_deployment.health_check_path}" if @app.current_deployment.health_check_path.present? %></dd>
          <dt>Deployed</dt>
          <dd><%= @app.current_deployment.deployed_at || "Not started" %></dd>
        </dl>
      <% else %>
        <p>No deployment has been created.</p>
      <% end %>

      <%= form_with url: deploy_app_path(@app), scope: :deployment, class: "stacked-form deployment-form" do |form| %>
        <div>
          <%= form.label :image_reference, "Deploy image" %>
          <%= form.text_field :image_reference, value: @app.current_deployment&.image_reference || @app.image_reference, placeholder: "ghcr.io/example/app:latest", required: true %>
        </div>

        <label class="checkbox-row">
          <%= form.check_box :start, checked: @app.status == "running" %>
          Start after deployment
        </label>

        <%= form.submit @app.current_deployment ? "Redeploy" : "Deploy" %>
      <% end %>
    </article>

    <article>
      <h2>Deployment History</h2>
      <% if @deployments.any? %>
        <ol class="event-list deployment-list">
          <% @deployments.each do |deployment| %>
            <li>
              <strong>
                Deployment <%= deployment.id %>
                <% if deployment.current? %>
                  <span class="status-pill">Current</span>
                <% end %>
              </strong>
              <span><%= deployment.image_reference %></span>
              <small><%= deployment.status.humanize %>, port <%= deployment.port %>, <%= deployment.created_at.to_fs(:short) %></small>
              <% unless deployment.current? %>
                <%= button_to "Rollback", rollback_app_path(@app),
                              method: :post,
                              params: { deployment_id: deployment.id },
                              class: "button compact secondary",
                              form: { data: { turbo_confirm: "Rollback to deployment #{deployment.id}?" } } %>
              <% end %>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p>No deployment history yet.</p>
      <% end %>
    </article>

    <article>
      <h2>Routes</h2>
      <% if @routes.any? %>
        <dl>
          <% @routes.each do |route| %>
            <dt><%= route.route_type.humanize %></dt>
            <dd>
              <%= route.hostname %>
              <span class="muted"><%= route.active? ? "active" : "inactive" %>, TLS <%= route.tls_status.humanize.downcase %></span>
            </dd>
          <% end %>
        </dl>
      <% else %>
        <p>No routes have been configured.</p>
      <% end %>
    </article>

    <article>
      <h2>Environment Variables</h2>
      <% if @environment_variables.any? %>
        <dl>
          <% @environment_variables.each do |environment_variable| %>
            <dt><%= environment_variable.key %></dt>
            <dd>
              <code><%= environment_variable.display_value %></code>
              <span class="muted"><%= environment_variable.secret? ? "secret" : "plain" %></span>
            </dd>
          <% end %>
        </dl>
      <% else %>
        <p>No environment variables configured.</p>
      <% end %>
    </article>

    <article>
      <h2>Persistent Storage</h2>
      <% if @app.volume %>
        <dl>
          <dt>Status</dt>
          <dd><%= @app.volume.status.humanize %></dd>
          <dt>Mount path</dt>
          <dd><code><%= @app.volume.mount_path %></code></dd>
          <dt>Host path</dt>
          <dd><code><%= @app.volume.host_path %></code></dd>
          <dt>Size limit</dt>
          <dd><%= @app.volume.size_limit_bytes.presence || "No limit configured" %></dd>
        </dl>
      <% else %>
        <p>No persistent volume configured.</p>
      <% end %>
    </article>

    <article>
      <h2>Shared Database</h2>
      <% if @app.database_resource %>
        <dl>
          <dt>Status</dt>
          <dd><%= @app.database_resource.status.humanize %></dd>
          <dt>Type</dt>
          <dd><%= @app.database_resource.database_type.humanize %></dd>
          <dt>Database</dt>
          <dd><code><%= @app.database_resource.database_name %></code></dd>
          <dt>Username</dt>
          <dd><code><%= @app.database_resource.username %></code></dd>
          <dt>Connection vars</dt>
          <dd><code><%= @app.database_resource.env_var_names.join(", ") %></code></dd>
          <dt>Secret values</dt>
          <dd><code><%= DatabaseResource::MASK %></code></dd>
          <dt>Provisioned</dt>
          <dd><%= @app.database_resource.provisioned_at || "Not provisioned" %></dd>
        </dl>
        <div class="inline-actions resource-actions">
          <%= button_to "Provision", provision_database_app_path(@app), method: :post, class: "button compact" %>
          <%= button_to "Rotate credentials", rotate_database_credentials_app_path(@app), method: :post, class: "button compact secondary", form: { data: { turbo_confirm: "Rotate database credentials now?" } } %>
          <%= button_to "Backup", backup_database_app_path(@app), method: :post, class: "button compact secondary" %>
        </div>
      <% else %>
        <p>No shared database configured.</p>
      <% end %>
    </article>

    <article>
      <h2>Database Backups</h2>
      <% if @database_backups.any? %>
        <dl>
          <% @database_backups.each do |backup| %>
            <dt><%= backup.status.humanize %></dt>
            <dd>
              <% if backup.completed? %>
                <%= link_to backup.filename, app_database_backup_path(@app, backup) %>
              <% else %>
                <%= backup.filename %>
              <% end %>
              <span class="muted"><%= backup.completed_at || backup.failure_message %></span>
            </dd>
          <% end %>
        </dl>
      <% else %>
        <p>No database backups have been created.</p>
      <% end %>
    </article>

    <article>
      <h2>Runtime Instance</h2>
      <% if @runtime_instance %>
        <dl>
          <dt>Status</dt>
          <dd><%= @runtime_instance.status %></dd>
          <dt>Container</dt>
          <dd><%= @runtime_instance.container_id.presence || "Not assigned" %></dd>
          <dt>Started</dt>
          <dd><%= @runtime_instance.started_at || "Not started" %></dd>
          <dt>Last seen</dt>
          <dd><%= @runtime_instance.last_seen_at || "Never" %></dd>
          <dt>Stopped</dt>
          <dd><%= @runtime_instance.stopped_at || "Not stopped" %></dd>
          <dt>Exit code</dt>
          <dd><%= @runtime_instance.exit_code.nil? ? "None" : @runtime_instance.exit_code %></dd>
          <dt>Health check result</dt>
          <dd><%= @runtime_instance.health_check_result.presence || "Not checked" %></dd>
          <dt>Health check status</dt>
          <dd><%= @runtime_instance.health_check_status_code.presence || "None" %></dd>
          <dt>Health checked</dt>
          <dd><%= @runtime_instance.health_check_checked_at || "Never" %></dd>
          <% if @runtime_instance.latest_metric_snapshot %>
            <dt>Memory usage</dt>
            <dd><%= number_to_human_size(@runtime_instance.latest_metric_snapshot.memory_usage_bytes) %></dd>
            <dt>CPU usage</dt>
            <dd><%= number_with_precision(@runtime_instance.latest_metric_snapshot.cpu_usage_percent, precision: 2) %>%</dd>
            <dt>Uptime</dt>
            <dd><%= pluralize(@runtime_instance.latest_metric_snapshot.uptime_seconds, "second") %></dd>
          <% end %>
        </dl>
      <% else %>
        <p>No runtime instance has been recorded.</p>
      <% end %>
    </article>

    <article>
      <h2>Request Metrics</h2>
      <dl>
        <dt>Total requests</dt>
        <dd><%= @app.request_count %></dd>
        <dt>Cold starts</dt>
        <dd><%= @app.cold_start_count %></dd>
        <dt>Average wake</dt>
        <dd><%= @app.average_wake_duration_ms ? "#{@app.average_wake_duration_ms} ms" : "No successful wakes" %></dd>
      </dl>
      <% if @request_metrics.any? %>
        <ol class="event-list metric-list">
          <% @request_metrics.each do |metric| %>
            <li>
              <strong><%= metric.cold_start? ? "Cold request" : "Warm request" %></strong>
              <span><%= [ metric.request_method, metric.path, metric.status_code ].compact.join(" ") %></span>
              <small><%= metric.occurred_at.to_fs(:short) %></small>
            </li>
          <% end %>
        </ol>
      <% end %>
    </article>

    <article>
      <h2>Runtime Metrics</h2>
      <% if @runtime_metrics.any? %>
        <ol class="event-list metric-list">
          <% @runtime_metrics.each do |metric| %>
            <li>
              <strong><%= number_to_human_size(metric.memory_usage_bytes) %></strong>
              <span><%= number_with_precision(metric.cpu_usage_percent, precision: 2) %>% CPU, <%= pluralize(metric.uptime_seconds, "second") %> uptime</span>
              <small><%= metric.captured_at.to_fs(:short) %></small>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p>No runtime snapshots have been captured.</p>
      <% end %>
    </article>

    <article>
      <h2>Cold Starts</h2>
      <% if @cold_start_metrics.any? %>
        <ol class="event-list metric-list">
          <% @cold_start_metrics.each do |metric| %>
            <li>
              <strong><%= metric.status.humanize %></strong>
              <span><%= metric.total_wake_duration_ms %> ms total, <%= metric.health_check_duration_ms || 0 %> ms readiness</span>
              <small><%= metric.started_at.to_fs(:short) %></small>
              <% if metric.failure_message.present? %>
                <small><%= metric.failure_message %></small>
              <% end %>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p>No cold start history has been recorded.</p>
      <% end %>
    </article>

    <article>
      <h2>Latest Logs</h2>
      <% if @latest_logs.any? %>
        <pre class="log-output"><% @latest_logs.reverse_each do |log| %><%= "[#{log.logged_at.to_fs(:db)}] #{log.stream}: #{log.message}" %>
<% end %></pre>
        <p class="card-action"><%= link_to "Open full logs", app_app_logs_path(@app) %></p>
      <% elsif @runtime_instance&.failure_message.present? %>
        <pre class="log-output"><%= @runtime_instance.failure_message %></pre>
        <p class="card-action"><%= link_to "Open full logs", app_app_logs_path(@app) %></p>
      <% else %>
        <p>Runtime log capture has not recorded output for this app yet.</p>
        <p class="card-action"><%= link_to "Open full logs", app_app_logs_path(@app) %></p>
      <% end %>
    </article>

    <article>
      <h2>Event Timeline</h2>
      <% if @events.any? %>
        <ol class="event-list">
          <% @events.each do |event| %>
            <li>
              <strong><%= event.event_type %></strong>
              <span><%= event.message %></span>
              <small><%= event.created_at.to_fs(:short) %></small>
              <% if event.metadata_summary.present? %>
                <small><%= event.metadata_summary %></small>
              <% end %>
              <% if event.related_runtime_instance_id.present? %>
                <small><%= link_to "Related logs", app_app_logs_path(@app, runtime_instance_id: event.related_runtime_instance_id) %></small>
              <% end %>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p>No events yet.</p>
      <% end %>
    </article>
  </section>
</main>
